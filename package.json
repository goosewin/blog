{
  "name": "goosewin-blog",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "test": "bun --bun vitest run --config vitest.config.ts",
    "lint": "bun --bun eslint .",
    "format": "bun --bun prettier --write .",
    "check": "bun --bun prettier --write . && bun --bun eslint --fix",
    "newsletter": "bash scripts/send-newsletter.sh",
    "deploy": "bunx --bun vercel --prod",
    "start": "bun --bun .output/server/index.mjs"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-start": "1.167.42",
    "@tanstack/router-plugin": "1.167.22",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260423-183501-f92fb7b7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.12.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/eslint-config": "0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  }
}
